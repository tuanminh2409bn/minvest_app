rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCTIONS ---
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             'role' in userDoc.data &&
             userDoc.data.role == 'admin';
    }

    function isSupport() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             'role' in userDoc.data &&
             userDoc.data.role == 'support';
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // --- COLLECTIONS ---

    match /signals/{signalId} {
      allow read: if true;
      allow write: if false;
    }

    match /profit_stats/{docId} {
      allow read: if true;
      allow write: if false; // Chỉ Cloud Function mới có quyền ghi (qua Admin SDK)
    }

    // Collection `users`
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        isAdmin() || 
        isSupport() || 
        (resource.data.referred_by_affiliate_id != null && 
         get(/databases/$(database)/documents/affiliates/$(resource.data.referred_by_affiliate_id)).data.uid == request.auth.uid)
      );
      
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if false;

      match /notifications/{notificationId} {
        allow read, update: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId;
        allow delete: if false;
      }

      match /transactions/{transactionId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // =======================================================
    // THÊM RULES CHO COLLECTION 'news' Ở ĐÂY
    // =======================================================
    match /news/{articleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    // =======================================================


    match /verifiedExnessIds/{exnessId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /processedTransactions/{transactionId} {
      allow read, write: if false;
    }

    match /chat_rooms/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isSupport());

      match /messages/{messageId} {
        allow read, create: if isSignedIn() && (request.auth.uid == userId || isSupport());
        allow update, delete: if false;
      }
    }

    // --- RULES CHO MÃ XÁC MINH ---
    match /signup_verification_codes/{email} {
      allow read: if true; // Cho phép đọc để kiểm tra mã khi đăng ký
      allow write: if false;
    }

    match /password_reset_codes/{email} {
      allow read: if true; // Cho phép đọc để kiểm tra mã khi quên mật khẩu
      allow write: if false;
    }

    // --- RULES CHO CẤU HÌNH HỆ THỐNG ---
    match /settings/{docId} {
      allow read: if true; 
      allow write: if isAdmin(); // Chỉ Admin mới có quyền sửa
    }

    // --- RULES CHO HỆ THỐNG AFFILIATE ---
    match /affiliates/{docId} {
      // Admin có toàn quyền, Affiliate có quyền xem dữ liệu của chính mình
      allow read: if isSignedIn() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /commissions/{docId} {
      // Admin có toàn quyền, Affiliate có quyền xem hoa hồng của mình dựa trên affiliateId
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource.data.affiliateId != null && 
         get(/databases/$(database)/documents/affiliates/$(resource.data.affiliateId)).data.uid == request.auth.uid)
      );
      allow create, update, delete: if isAdmin();
    }

    match /payouts/{docId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }
  }
}
